{
  "baseUrl": "http://localhost:5173/ruidu-docs",
  "outputDir": "./tmp",
  "defaultModule": "orbitcontrol",
  "pdf": {
    "format": "A4",
    "margin": {
      "top": "20mm",
      "right": "20mm",
      "bottom": "20mm",
      "left": "20mm"
    },
    "printBackground": true,
    "preferCSSPageSize": false,
    "displayHeaderFooter": true,
    "headerTemplate": "<div style=\"font-size: 10px; text-align: center; width: 100%;\"></div>",
    "footerTemplate": "<div style=\"font-size: 10px; text-align: center; width: 100%; margin: 0 auto;\"><span class=\"pageNumber\"></span> / <span class=\"totalPages\"></span></div>"
  },
  "chrome": {
    "headless": "new",
    "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  }
}
